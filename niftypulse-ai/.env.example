# Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase API key (public anon key or service role key)
SUPABASE_KEY=your_supabase_api_key_here

# Redis connection URL (used for caching / queues)
REDIS_URL=redis://localhost:6379/0

# Primary database connection string (PostgreSQL example)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Secret key for signing/authentication (use a long random string in production)
SECRET_KEY=your_secret_key_here

# Directory path for yfinance cache storages
YFINANCE_CACHE_DIR=/tmp/yfinance-cache

# MLflow tracking server URI
MLFLOW_TRACKING_URI=http://localhost:5000

# Celery broker URL for async tasks (can reuse Redis)
CELERY_BROKER_URL=redis://localhost:6379/0